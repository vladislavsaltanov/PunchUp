# ===========================================
# PunchUp — .gitattributes
# Unity 6.2 / FMOD / C#
# ===========================================

# Auto-detect text files, normalize line endings to LF in repo
* text=auto eol=lf

# ---- Unity YAML (merge driver + force LF) ----
*.unity     merge=unityyamlmerge eol=lf
*.prefab    merge=unityyamlmerge eol=lf
*.asset     merge=unityyamlmerge eol=lf
*.meta      merge=unityyamlmerge eol=lf
*.mat       merge=unityyamlmerge eol=lf
*.anim      merge=unityyamlmerge eol=lf
*.controller          merge=unityyamlmerge eol=lf
*.overrideController  merge=unityyamlmerge eol=lf
*.playable            merge=unityyamlmerge eol=lf
*.renderTexture       merge=unityyamlmerge eol=lf
*.flare               merge=unityyamlmerge eol=lf
*.fontsettings        merge=unityyamlmerge eol=lf
*.guiskin             merge=unityyamlmerge eol=lf
*.physicsMaterial     merge=unityyamlmerge eol=lf
*.physicsMaterial2D   merge=unityyamlmerge eol=lf
*.brush               merge=unityyamlmerge eol=lf
*.spriteatlas         merge=unityyamlmerge eol=lf
*.spriteatlasv2       merge=unityyamlmerge eol=lf
*.terrainlayer        merge=unityyamlmerge eol=lf
*.mixer               merge=unityyamlmerge eol=lf

# ---- Scripts / shaders (text, LF) ----
*.cs      text eol=lf
*.shader  text eol=lf
*.cginc   text eol=lf
*.hlsl    text eol=lf
*.glsl    text eol=lf
*.compute text eol=lf

# ---- Config / data (text) ----
*.json  text eol=lf
*.xml   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.asmdef text eol=lf

# ---- Images (binary) ----
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.tga   binary
*.tif   binary
*.tiff  binary
*.psd   binary
*.exr   binary
*.hdr   binary
*.ico   binary
*.aseprite binary
*.ase   binary

# ---- Audio (binary) ----
*.wav   binary
*.mp3   binary
*.ogg   binary
*.aif   binary
*.aiff  binary
*.flac  binary

# ---- FMOD (binary) ----
*.bank         binary
*.strings.bank binary

# ---- Native libs / executables (binary) ----
*.dll   binary
*.exe   binary
*.so    binary
*.dylib binary
*.pdb   binary

# ---- Fonts (binary) ----
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

Assets/Plugins/FMOD/**/*.bundle text eol=lf
Assets/Plugins/FMOD/**/Info.plist text eol=lf